---
import RootLayout from '@/components/layouts/root-layout.astro';
import Header from '@components/ui/header/header.astro';
import Footer from '@components/ui/footer.astro';
import { resolvePath } from '@/modules/resolve-path';
---

<RootLayout title="404" description="Page Not Found">
	<Header />
	<main class="flex-1 flex items-center">
		<section class="container mx-auto p-4 flex flex-col justify-center items-center gap-4">
			<div class="text-4xl font-bold">PocketBuilds</div>
			<h2 class="h2">Page Not Found</h2>
			<p class="opacity-60">Sorry, this page does not appear to exist (anymore).</p>
			<a href={resolvePath(Astro.params, '/')} class="btn preset-filled">Go back home</a>
		</section>
	</main>
	<Footer />
</RootLayout>
