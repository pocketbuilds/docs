---
import { resolvePath } from '@/modules/resolve-path';
import { commonSections, type Section } from '@/modules/navigation';
import { toPublicDocPath } from '@/modules/docs-path';
import { removeTrailingSlash } from '@/modules/normalize-path';
import { cn } from '@/modules/utils';

interface Props {
	sections?: Section[];
}

const { sections = commonSections } = Astro.props;
---

<div class="text-sm grid gap-10">
	{
		sections.map(async (section) => (
			<nav class="flex flex-col gap-2">
				<span class="text-[12px] font-bold ml-2 text-surface-600-400 uppercase">{section.label}</span>
				<ul class="flex flex-col gap-1">
					{section.docs.map((doc) => (
						<li>
							<a
								href={resolvePath(Astro.params, toPublicDocPath(doc.id))}
								title={doc.data.title}
								class="hover:preset-tonal aria-[current=page]:preset-tonal btn flex justify-between items-center px-2"
								aria-current={
									removeTrailingSlash(Astro.url.pathname) === resolvePath(Astro.params, toPublicDocPath(doc.id))
										? 'page'
										: 'false'
								}
							>
								<span class="text-sm">{doc.data.title}</span>
								{doc.data.stability !== 'stable' && (
									<span
										class={cn(
											"no-underline text-xs px-1 capitalize rounded",
											doc.data.stability === "dev"
												? "preset-tonal-warning"
												: "preset-tonal-primary",
										)}
									>
										{doc.data.stability}
									</span>
								)}
							</a>
						</li>
					))}
				</ul>
			</nav>
		))
	}
</div>
