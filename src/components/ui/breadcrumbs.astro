---
import { resolvePath } from '@/modules/resolve-path';
import { toPublicDocPath, toPublicDocId } from '@/modules/docs-path';
import { getCollection } from '@/modules/content';

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL.replace(/\/+$/, '');
const path = Astro.url.pathname.replace(base, '');

const segments = path.split('/').filter(Boolean);
const allDocs = await getCollection('docs');

function titleCaseFromSlug(slug: string) {
	return slug
		.split('-')
		.filter(Boolean)
		.map((part) =>
			part.length <= 3 ? part.toUpperCase() : part.slice(0, 1).toUpperCase() + part.slice(1),
		)
		.join(' ');
}

const crumbs = await Promise.all(
	segments.map(async (segment, i) => {
		const label = titleCaseFromSlug(segment);
		const isFirst = i === 0;
		const isLast = i === segments.length - 1;

		if (isFirst || isLast) {
			return {
				label,
			};
		}

		const publicId = segments.slice(0, i + 1).join('/');
		const doc = allDocs.find((d) => toPublicDocId(d.id) === publicId);

		if (doc) {
			const hrefId = toPublicDocPath(doc.id);
			return {
				label: doc.data.title,
				href: resolvePath(Astro.params, hrefId),
			};
		}

		return {
			label,
		};
	}),
);
---

<ol class="flex flex-wrap gap-2 text-xs">
	{
		crumbs.map((crumb, i) => (
			<>
				<li class="capitalize" class:list={{ 'opacity-60': i === crumbs.length - 1 }}>
					{crumb.href ? (
						<a href={crumb.href} class="hover:underline">
							{crumb.label}
						</a>
					) : (
						crumb.label
					)}
				</li>
				{i < crumbs.length - 1 && <li class="opacity-60">›</li>}
			</>
		))
	}
</ol>
