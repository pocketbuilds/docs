---
import { SITE_THEME } from '@/modules/site-config';
---

<script is:inline define:vars={{ SITE_THEME }}>
	function applyTheme(document = window.document) {
		document.documentElement.setAttribute('data-theme', SITE_THEME);
	}

	applyTheme();

	document.addEventListener('astro:before-swap', (event) => applyTheme(event.newDocument));
</script>
