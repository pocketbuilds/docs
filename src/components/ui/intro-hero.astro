---
import faviconSvg from '@/assets/favicon.svg';
import introVideo from '@/assets/intro_to_pocketbuilds.mp4';

interface Props {
	title?: string;
	videoSrc?: string;
}

const { title = 'PocketBuilds', videoSrc = introVideo } = Astro.props;
---

<section class="not-prose grid gap-6">
	<div class="card border-surface-200-800 overflow-hidden relative">
		<div
			class="absolute inset-0 bg-top bg-repeat"
			style={`background-image: url('https://pocketbuilds.com/static/birch-base-darker.svg'); background-size: 640px auto;`}
		/>
		<img
			src="https://pocketbuilds.com/static/trees.svg"
			class="absolute bottom-0 left-0 w-full h-[120px] object-cover object-bottom opacity-95"
			alt=""
		/>
		<img
			src="https://pocketbuilds.com/static/gophers/caveman-gopher-bald.svg"
			class="hero-gopher absolute right-6 bottom-0 h-24 transition-transform"
			alt=""
		/>
		<div class="absolute bottom-0 left-0 right-0 h-10 bg-surface-50-950/70 backdrop-blur-sm border-t border-surface-200-800"></div>
		<div class="relative h-[160px] sm:h-[200px] flex items-center justify-center">
			<div class="px-6 py-6 sm:py-8 flex flex-col items-center gap-3 text-center">
				<img src={faviconSvg.src} class="size-14 sm:size-16" alt="" />
				<div class="text-xl sm:text-2xl text-surface-50 font-bold tracking-tight">{title}</div>
			</div>
		</div>
	</div>

	<div class="card border border-surface-200-800 overflow-hidden bg-surface-50-950">
		<video
			class="w-full aspect-video object-cover"
			src={videoSrc}
			controls
			playsinline
			preload="metadata"
		>
			<p class="p-4 text-sm opacity-70">
				Your browser doesn't support HTML5 video. Download it <a class="underline" href={videoSrc}>here</a>.
			</p>
		</video>
	</div>
	<style>
		.hero-gopher{transform:translateY(0)}
		section:hover .hero-gopher{transform:translateY(8px)}
	</style>
</section>
